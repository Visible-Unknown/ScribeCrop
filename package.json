{
  "name": "scribecrop-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "web",
    "desktop"
  ],
  "scripts": {
    "web:dev":     "npm run dev     --workspace=web",
    "web:build":   "npm run build   --workspace=web",
    "web:start":   "npm run start   --workspace=web",

    "desktop:install": "npm install --workspace=desktop",
    "desktop:dev":     "npm run dev     --workspace=desktop",
    "desktop:preview": "npm run preview --workspace=desktop",
    "desktop:build":   "npm run build   --workspace=desktop",

    "build": "npm run web:build && npm run desktop:build"
  }
}
