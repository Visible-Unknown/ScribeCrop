{
  "name": "scribecrop-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop wrapper for ScribeCrop",
  "main": "main.js",
  "scripts": {
    "dev": "set ELECTRON_DEV=1 && electron .",
    "preview": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.scribecrop.desktop",
    "productName": "ScribeCrop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "../web/out",
        "to": "app/out",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../web/public/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "../web/public/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "../web/public/icon.png"
    }
  },
  "devDependencies": {
    "electron": "29.1.0",
    "electron-builder": "^24.13.3",
    "electron-serve": "^1.3.0"
  }
}
